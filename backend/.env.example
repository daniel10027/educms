# =====================================================
# SERVER
# =====================================================
PORT=5000
NODE_ENV=production
API_VERSION=v1

# =====================================================
# DATABASE (Render/Railway provide DATABASE_URL automatically)
# =====================================================
# If DATABASE_URL is set, it takes priority over the individual fields below.
DATABASE_URL=postgresql://user:password@host:5432/educms_db
DB_HOST=localhost
DB_PORT=5432
DB_NAME=educms_db
DB_USER=postgres
DB_PASSWORD=change_me
DB_SSL=true
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_IDLE_TIMEOUT=30000
DB_CONNECTION_TIMEOUT=5000

# =====================================================
# JWT
# =====================================================
JWT_SECRET=change_this_to_a_random_64_character_string_in_production
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=change_this_too_a_different_random_64_character_string
JWT_REFRESH_EXPIRE=30d

# =====================================================
# REDIS (optional — app degrades gracefully without it)
# =====================================================
REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379

# =====================================================
# FILE UPLOAD
# =====================================================
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,image/webp,application/pdf

# =====================================================
# EMAIL (optional — used for verification/notifications)
# =====================================================
EMAIL_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@educms.local

# =====================================================
# SECURITY
# =====================================================
BCRYPT_ROUNDS=10
RATE_LIMIT_WINDOW_MINUTES=15
RATE_LIMIT_MAX_REQUESTS=200
AUTH_RATE_LIMIT_MAX_REQUESTS=20

# =====================================================
# CORS
# =====================================================
FRONTEND_URL=http://localhost:5173

# =====================================================
# LOGGING
# =====================================================
LOG_LEVEL=info

# =====================================================
# PAGINATION
# =====================================================
DEFAULT_PAGE_SIZE=10
MAX_PAGE_SIZE=100
